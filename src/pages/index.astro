---
const researchInterests = [
	'Topology Optimization',
	'Topology Optimization for Turbulent Flows',
	'Computational Fluid Dynamics',
	'Numerical Analysis',
	'Partial Differential Equations',
	'Scientific Computing',
];

const education = [
	{
		degree: 'Special Research Student',
		institution: 'Osaka University',
		location: 'Osaka, Japan',
		period: 'Apr 2026 – Apr 2027',
		details: 'Visiting student in the research group of Prof. Kentaro Yaji',
	},
	{
		degree: 'Master of Science in Mathematics',
		institution: 'East China Normal University',
		location: 'Shanghai, China',
		period: 'Sep 2024 – Jun 2027 (Expected)',
		details: '',
	},
	{
		degree: 'Bachelor of Science in Physics',
		institution: 'East China Normal University',
		location: 'Shanghai, China',
		period: 'Sep 2020 – Jun 2024',
		details: '',
	},
];

const publications = [
	{
		title: 'Topology Optimization for Microfluidic Mixers by a Phase Field Method',
		authors: 'Zongyuan Liu, Jiajie Li, and Shengfeng Zhu',
		journal: 'International Journal for Numerical Methods in Fluids',
		year: '2026',
		pages: '1–17',
		doi: '10.1002/fld.70083',
		url: 'https://doi.org/10.1002/fld.70083',
	},
];

const projects = [
	{
		title: 'Topology Optimization for Unsteady and Turbulent Flows',
		period: 'Apr 2026 – Apr 2027',
		tools: 'C++, Lattice Boltzmann Method, LES, Discrete Adjoint Method',
		description:
			'Conducting research as a visiting Special Research Student in Prof. Kentaro Yaji’s research group at Osaka University. The work focuses on topology optimization for unsteady and turbulent flows.',
	},
	{
		title: 'Topology Optimization of Multiphysics Fluid Systems',
		period: 'Oct 2024 – Jun 2025',
		tools: 'FreeFEM++, Python',
		description:
			'Studied phase-field-based topology optimization for coupled Poisson–Boltzmann, Navier–Stokes, and convection–diffusion systems, with applications to microfluidic mixing.',
	},
	{
		title: 'Simulation of Poisson–Nernst–Planck Equations in Electrolytes',
		period: 'Dec 2023 – Mar 2024',
		tools: 'MATLAB',
		description:
			'Reproduced a two-dimensional exponential-fitting method for drift–diffusion models and verified its convergence and stability using benchmark problems.',
	},
	{
		title: 'Quantum Thermalization of a Single Atom in Strong Magnetic Fields',
		period: 'Nov 2022 – Apr 2023',
		tools: 'Fortran 90, MATLAB',
		description:
			'Numerically computed hydrogen energy levels under strong magnetic fields and analyzed the transition of level statistics from Poisson to Wigner–Dyson distributions.',
	},
	{
		title: 'Face Recognition Based on Laser-Induced Photonic Lattices',
		period: 'Jun 2023 – Oct 2023',
		tools: 'MATLAB, Mathematica',
		description:
			'Developed data-processing algorithms and implemented a basic face-recognition method as part of a collaborative research project.',
	},
];

const skills = [
	'Python',
	'MATLAB',
	'FreeFEM++',
	'Fortran 90',
	'Mathematica',
	'C',
];

const awards = [
	'University-Level Outstanding Graduate, East China Normal University, 2024',
	'National-Level Undergraduate Innovation and Entrepreneurship Training Project, Project Leader, 2023',
	'Municipal-Level Undergraduate Innovation and Entrepreneurship Project, Shanghai, Project Member, 2023',
	'Excellent Undergraduate Scholarship, 2020–2021',
	'Excellent Undergraduate Scholarship, 2021–2022',
	'Excellent Undergraduate Scholarship, 2022–2023',
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="Academic homepage of Zongyuan Liu, a graduate student in mathematics working on topology optimization, computational fluid dynamics, and scientific computing."
		/>
		<title>Zongyuan Liu</title>
	</head>

	<body>
		<header>
			<nav>
				<a class="name" href="/">Zongyuan Liu</a>

				<div class="links">
				<a href="#about">About</a>
				<a href="#education">Education</a>
				<a href="#research">Research</a>
				<a href="#publications">Publications</a>
				<a href="#projects">Experience</a>
				<a href="#skills">Skills</a>
				<a href="#contact">Contact</a>
			</div>
			</nav>
		</header>

		<main>
			<section class="hero">
				<p class="eyebrow">
					Mathematics · Computational Science · Fluid Mechanics
				</p>

				<h1>Zongyuan Liu</h1>

				<p class="intro">
					Graduate student in mathematics at East China Normal University.
				</p>

				<p class="description">
					My research interests include topology optimization, computational
					fluid dynamics, numerical analysis, partial differential equations,
					and scientific computing.
				</p>

				<div class="buttons">
					<a class="primary" href="#research">Research interests</a>
					<a class="secondary" href="#contact">Contact</a>
				</div>
			</section>

			<section id="about">
				<div class="section-title">
					<span>01</span>
					<h2>About</h2>
				</div>

				<div class="two-columns">
					<div>
						<p>
							I received my bachelor’s degree in physics from East China
							Normal University and am currently pursuing a master’s degree
							in mathematics.
						</p>

						<p>
							My academic interests lie at the intersection of mathematical
							modeling, numerical methods, fluid mechanics, and optimization.
						</p>
					</div>

					<div class="panel">
						<h3>Current status</h3>
						<p>Master’s student in Mathematics</p>
						<p>East China Normal University</p>
						<p>Expected graduation: June 2027</p>
					</div>
				</div>
			</section>

			<section id="education" class="alternate">
				<div class="section-title">
					<span>02</span>
					<h2>Education</h2>
				</div>

				<div class="timeline">
					{
						education.map((item) => (
							<article class="education-item">
								<div>
									<h3>{item.degree}</h3>
									<p>{item.institution}</p>
									<p class="muted">{item.location}</p>
									{item.details && <p class="education-details">{item.details}</p>}
								</div>

								<p class="period">{item.period}</p>
							</article>
						))
					}
				</div>
			</section>

			<section id="research">
				<div class="section-title">
					<span>03</span>
					<h2>Research Interests</h2>
				</div>

				<div class="interest-grid">
					{
						researchInterests.map((interest) => (
							<article>
								<h3>{interest}</h3>
							</article>
						))
					}
				</div>
			</section>
			
			<section id="publications" class="alternate">
				<div class="section-title">
					<span>04</span>
					<h2>Publications</h2>
				</div>

				<div class="publication-list">
					{
						publications.map((publication) => (
							<article class="publication">
								<p class="publication-year">{publication.year}</p>

								<h3>{publication.title}</h3>

								<p class="publication-authors">
									<strong>Zongyuan Liu</strong>, Jiajie Li, and Shengfeng Zhu
								</p>

								<p class="publication-journal">
									<em>{publication.journal}</em>, {publication.pages}, {publication.year}.
								</p>

								<a
									class="doi-link"
									href={publication.url}
									target="_blank"
									rel="noreferrer"
								>
									DOI: {publication.doi}
								</a>
							</article>
						))
					}
				</div>
			</section>

			<section id="projects" class="alternate">
				<div class="section-title">
					<span>04</span>
					<h2>Research Experience</h2>
				</div>

				<div class="projects">
					{
						projects.map((project) => (
							<article>
								<p class="period">{project.period}</p>
								<h3>{project.title}</h3>
								<p class="tools">{project.tools}</p>
								<p>{project.description}</p>
							</article>
						))
					}
				</div>
			</section>

			<section id="skills">
				<div class="section-title">
					<span>05</span>
					<h2>Skills</h2>
				</div>

				<div class="interest-grid">
					{
						skills.map((skill) => (
							<article>
								<h3>{skill}</h3>
							</article>
						))
					}
				</div>
			</section>

			<section id="awards" class="alternate">
				<div class="section-title">
					<span>06</span>
					<h2>Honors and Awards</h2>
				</div>

				<div class="panel">
					<ul class="award-list">
						{awards.map((award) => <li>{award}</li>)}
					</ul>
				</div>
			</section>

			<section id="contact">
				<div class="section-title">
					<span>08</span>
					<h2>Contact</h2>
				</div>

				<p class="contact-text">
					I am always happy to discuss research topics related to topology
					optimization, computational fluid dynamics, and scientific computing.
				</p>

				<div class="contact-info">

					<p>
						<strong>Email:</strong>
						<a href="mailto:51275500058@stu.ecnu.edu.cn">
							51275500058@stu.ecnu.edu.cn
						</a>
					</p>

					<p>
						<strong>GitHub:</strong>
						<a
							href="https://github.com/karuqo-crypto"
							target="_blank"
							rel="noreferrer"
						>
							github.com/karuqo-crypto
						</a>
					</p>

					<p>
						<strong>ResearchGate:</strong>
						<a
							href="https://www.researchgate.net/profile/Liu-Zongyuan-2/research"
							target="_blank"
							rel="noreferrer"
						>
							View my ResearchGate profile
						</a>
					</p>

				</div>
			</section>
		</main>

		<footer>
			<p>© 2026 Zongyuan Liu.</p>
		</footer>
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body) {
		margin: 0;
		background: #f7f8fa;
		color: #17202a;
		font-family:
			Inter,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			sans-serif;
		line-height: 1.7;
	}

	a {
		color: inherit;
	}

	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid #dfe5ea;
		background: rgba(247, 248, 250, 0.92);
		backdrop-filter: blur(12px);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1080px;
		min-height: 68px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.name {
		font-weight: 700;
		text-decoration: none;
	}

	.links {
		display: flex;
		gap: 22px;
	}

	.links a {
		color: #5f6b76;
		font-size: 0.92rem;
		text-decoration: none;
	}

	.links a:hover {
		color: #245b88;
	}

	main {
		width: 100%;
	}

	section {
		max-width: 1080px;
		margin: 0 auto;
		padding: 96px 24px;
	}

	.hero {
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-height: 76vh;
	}

	.eyebrow,
	.period,
	.section-title span {
		color: #245b88;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		margin: 14px 0 20px;
		font-size: clamp(3.7rem, 10vw, 7rem);
		line-height: 0.95;
		letter-spacing: -0.06em;
	}

	.education-details {
		margin-top: 10px;
		color: #5f6b76;
		font-size: 0.95rem;
	}

	.intro {
		max-width: 780px;
		margin: 0 0 14px;
		font-size: clamp(1.25rem, 2.3vw, 1.65rem);
	}

	.description {
		max-width: 760px;
		margin: 0 0 34px;
		color: #5f6b76;
		font-size: 1.1rem;
	}

	.buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}

	.buttons a {
		padding: 10px 17px;
		border: 1px solid #245b88;
		border-radius: 6px;
		font-weight: 600;
		text-decoration: none;
	}

	.primary {
		background: #245b88;
		color: white;
	}

	.secondary {
		color: #245b88;
	}

	.section-title {
		display: flex;
		align-items: baseline;
		gap: 16px;
		margin-bottom: 42px;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3rem);
		letter-spacing: -0.04em;
	}

	h3 {
		margin-top: 0;
	}

	.two-columns {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 56px;
	}

	.panel,
	.education-item,
	.interest-grid article,
	.projects article {
		border: 1px solid #dfe5ea;
		border-radius: 10px;
		background: white;
	}

	.panel {
		padding: 28px;
	}

	.alternate {
		max-width: none;
		padding-right: max(24px, calc((100vw - 1080px) / 2 + 24px));
		padding-left: max(24px, calc((100vw - 1080px) / 2 + 24px));
		background: #edf2f5;
	}

	.timeline {
		display: grid;
		gap: 16px;
	}

	.education-item {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 30px;
		padding: 24px;
	}

	.education-item p {
		margin: 4px 0;
	}

	.muted,
	.projects p,
	.contact-text {
		color: #5f6b76;
	}

	.interest-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 18px;
	}

	.interest-grid article,
	.projects article {
		padding: 24px;
	}

	.projects {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 18px;
	}

	.tools {
		font-weight: 600;
	}

	.award-list {
		margin: 0;
		padding-left: 20px;
	}

	.award-list li + li {
		margin-top: 10px;
	}
	.publication-list {
	display: grid;
	gap: 18px;
}

	.publication {
		padding: 28px;
		border: 1px solid #dfe5ea;
		border-radius: 10px;
		background: white;
	}

	.publication h3 {
		max-width: 850px;
		margin-bottom: 12px;
		font-size: 1.25rem;
		line-height: 1.45;
	}

	.publication-year {
		margin: 0 0 10px;
		color: #245b88;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.publication-authors,
	.publication-journal {
		margin: 5px 0;
		color: #5f6b76;
	}

	.doi-link {
		display: inline-block;
		margin-top: 14px;
		color: #245b88;
		font-weight: 600;
		text-decoration: none;
	}

	.doi-link:hover {
		text-decoration: underline;
	}

	.contact-text {
		max-width: 700px;
		font-size: 1.1rem;
	}

	footer {
		padding: 34px 24px;
		border-top: 1px solid #dfe5ea;
		color: #5f6b76;
		text-align: center;
	}

	@media (max-width: 760px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			gap: 8px;
			padding-top: 14px;
			padding-bottom: 14px;
		}

		.links {
			width: 100%;
			gap: 14px;
			overflow-x: auto;
		}

		.two-columns,
		.interest-grid,
		.projects {
			grid-template-columns: 1fr;
		}

		.education-item {
			flex-direction: column;
			gap: 8px;
		}

		.hero {
			min-height: auto;
			padding-top: 88px;
			padding-bottom: 80px;
		}

		section {
			padding-top: 74px;
			padding-bottom: 74px;
		}
	}
</style>